%%%%%%% FRONT PAGE

% Define fonts and colors
\definecolor{gray}{cmyk}{0, 0, 0, .50}

% Define titlepage
\newcommand{\serialnumber}[1]{\gdef\@serialnumber{#1}}
\newcommand{\@serialnumber}{[Ange serienummer]}
\newcommand{\credits}[1]{\gdef\@credits{#1}}
\newcommand{\@credits}{[Ange antal HP]}
\newcommand{\subtitle}[1]{\gdef\@subtitle{#1}}
\newcommand{\@subtitle}{[Ange undertitel]}
\newcommand{\program}[1]{\gdef\@program{#1}}
\newcommand{\@program}{[Ange program]}

\renewcommand{\maketitle}{
    \thispagestyle{empty}
    \pagenumbering{gobble}
    \begin{titlepage}
        \newgeometry{left=5cm,right=2cm,bottom=1cm,top=1cm}
        \begin{tikzpicture}[overlay, remember picture]
            \node[anchor=north west, xshift=1cm, yshift=-1cm] at (current page.north west) {\includegraphics[width=4.2cm]{./dependencies/logo_side.pdf}};
        \end{tikzpicture}
        \begin{flushright}
        
            {\color{gray}\@helvfont{10}{12}\selectfont \@serialnumber}
            
        
            {\@helvfont{14}{16.8}\selectfont Degree project {\color{gray}\@credits} credits}
            
            {\color{gray}\@helvfont{14}{15.12}\selectfont \@date}
        \end{flushright}
        
        \vspace{30pt}

        \begin{flushleft}
            \setstretch{2.3}    
            {\color{gray}\@helvfont{28}{33.6}\selectfont \@title}
            \vspace{-10pt}
        \end{flushleft}

 
        \ifthenelse{\equal{\@subtitle}{}}%
        {}% Do nothing if subtitle is empty
        { % Otherwise display subtitle
            \begin{flushleft}
                \vspace{-6pt}
                \setstretch{1.3}    
                {\color{gray}\@helvfont{16}{19.2}\selectfont \@subtitle}
                \vspace{-12pt}
            \end{flushleft}
        }

        \vspace{4pt}
        \hrule height 0.8pt
        \vspace{4pt}

        {\@helvfont{16}{17.28}\selectfont \@author}
        
        \vfill
        
        \begin{tikzpicture}[overlay, remember picture]
            \node[anchor=south east, xshift=3pt, yshift=-3pt] at (current page.south east) {\includegraphics{./dependencies/logo_side.pdf}};
        \end{tikzpicture}

        \begin{flushright}
            \color{gray}\@helvfont{16}{16}\selectfont \@program
        \end{flushright}
    \end{titlepage}
}

%%%%%%% ABSTRACT
\newcommand{\supervisor}[1]{\gdef\@supervisor{#1}}
\newcommand{\@supervisor}{[Ange handledare]}
\newcommand{\reviewer}[1]{\gdef\@reviewer{#1}}
\newcommand{\@reviewer}{[Ange ämnesgranskare]}
\newcommand{\examinator}[1]{\gdef\@examinator{#1}}
\newcommand{\@examinator}{Ange examinator}
\newcommand{\secrecy}[1]{\gdef\@secrecy{#1}}
\newcommand{\@secrecy}{}

\renewenvironment{abstract}{
    \thispagestyle{empty}
    \newgeometry{left=7.2cm,right=2cm,bottom=1cm,top=1cm}
    \begin{tikzpicture}[overlay, remember picture]
        \node[anchor=north west, xshift=1cm, yshift=-1cm] at (current page.north west) {\includegraphics[width=4.2cm]{./dependencies/logo_side.pdf}};
    \end{tikzpicture}
    \vspace{12pt}
    
    {\color{gray}\@helvfont{12}{14.4}\selectfont\@title}
    
    \vspace{8pt}
    \hrule

    {\@helvfont{10}{12}\selectfont \@author}

    \vspace{1.7cm}

    \begin{addmargin}[-4.6cm]{0cm}
    {\bfseries \@helvfont{12}{16}\selectfont Abstract}
    \@helvfont{11}{13.2}\selectfont
    
}{
    \vfill
    \begin{center}
        \color{gray}
        {
            \bfseries\@helvfont{12}{16}\selectfont
            Faculty of Science and Technology

            \vspace{-2pt}
            
            Uppsala University, Place of publication Uppsala
            
            \vspace{4pt}
        }{
            \@helvfont{9}{15}\selectfont
            Supervisor: {\@supervisor}\;\; Subject reader: {\@reviewer}

            \vspace{-6pt}
            Examiner: {\@examinator}

            \@secrecy
        }
    \end{center}
    \end{addmargin}
    \clearpage
}

